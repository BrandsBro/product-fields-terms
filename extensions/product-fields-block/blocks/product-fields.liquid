<style>
  .pf-wrapper { display:flex; flex-direction:column; gap:12px; margin:12px 0; width:100%; box-sizing:border-box; }
  .pf-field { display:flex; flex-direction:column; gap:6px; width:100%; box-sizing:border-box; }
  .pf-label { font-size:14px; font-weight:500; color:#1a1a1a; }
  .pf-input, .pf-select { width:100%; padding:10px 12px; border:1px solid #d1d5db; border-radius:6px; font-size:14px; box-sizing:border-box; background:white; font-family:inherit; }
  .pf-input:focus, .pf-select:focus { outline:none; border-color:#000; }
  .pf-checkbox-wrap { display:flex; align-items:center; gap:8px; }
  .pf-agreement-wrap { display:flex; align-items:flex-start; gap:8px; padding:12px; background:#f9fafb; border-radius:6px; border:1px solid #e5e7eb; }
  .pf-checkbox { width:16px; height:16px; cursor:pointer; flex-shrink:0; margin-top:2px; }
  .pf-checkbox-label { font-size:14px; color:#1a1a1a; cursor:pointer; line-height:1.5; }
</style>

<div id="pf-block-{{ block.id }}"></div>

<script>
(function() {
  var shop = {{ shop.permanent_domain | json }};
  var productId = {{ product.id | json }};
  var blockId = "{{ block.id }}";
  var appUrl = 'https://product-fields-terms.onrender.com';
  var groupIds = {{ block.settings.group_ids | json }};
  var styles = {
    labelColor: {{ block.settings.label_color | json }},
    labelSize: {{ block.settings.label_size | json }} + 'px',
    inputBg: {{ block.settings.input_bg | json }},
    inputBorderColor: {{ block.settings.input_border_color | json }},
    inputBorderRadius: {{ block.settings.input_border_radius | json }} + 'px',
    inputTextColor: {{ block.settings.input_text_color | json }},
    agreementBg: {{ block.settings.agreement_bg | json }},
    agreementBorderColor: {{ block.settings.agreement_border_color | json }},
  };
  var pfFields = [];



  var apiUrl = appUrl + '/api/fields?shop=' + shop + '&productId=' + productId;
  if (groupIds) apiUrl += '&groupIds=' + encodeURIComponent(groupIds);
  fetch(apiUrl)
    .then(function(res) { return res.json(); })
    .then(function(data) {
      var container = document.getElementById('pf-block-' + blockId);
      if (!container || !data.fields || data.fields.length === 0) return;

      pfFields = data.fields;
      var wrapper = document.createElement('div');
      wrapper.className = 'pf-wrapper';
      wrapper.id = 'pf-wrapper-' + blockId;

      data.fields.forEach(function(field) {
        var fieldDiv = document.createElement('div');
        fieldDiv.className = 'pf-field';

        var lbl, inp, sel, div;

        if (field.type === 'TEXT') {
          lbl = document.createElement('label');
          lbl.textContent = field.label;
          lbl.style.cssText = 'display:block; margin-bottom:4px; font-weight:500; color:' + styles.labelColor + '; font-size:' + styles.labelSize + ';';
          inp = document.createElement('input');
          inp.type = 'text';
          inp.dataset.pfLabel = field.label;
          inp.placeholder = field.placeholder || '';
          inp.style.cssText = 'width:100%; padding:10px 12px; border:1px solid ' + styles.inputBorderColor + '; border-radius:' + styles.inputBorderRadius + '; font-size:14px; box-sizing:border-box; background:' + styles.inputBg + '; color:' + styles.inputTextColor + '; font-family:inherit;';
          fieldDiv.appendChild(lbl);
          fieldDiv.appendChild(inp);

        } else if (field.type === 'DROPDOWN') {
          lbl = document.createElement('label');
          lbl.textContent = field.label;
          lbl.style.cssText = 'display:block; margin-bottom:4px; font-weight:500; color:' + styles.labelColor + '; font-size:' + styles.labelSize + ';';
          sel = document.createElement('select');
          sel.dataset.pfLabel = field.label;
          sel.style.cssText = 'width:100%; padding:10px 12px; border:1px solid ' + styles.inputBorderColor + '; border-radius:' + styles.inputBorderRadius + '; font-size:14px; box-sizing:border-box; background:' + styles.inputBg + '; color:' + styles.inputTextColor + '; font-family:inherit;';
          var defaultOpt = document.createElement('option');
          defaultOpt.value = '';
          defaultOpt.textContent = 'Select an option';
          sel.appendChild(defaultOpt);
          (field.options || []).forEach(function(opt) {
            var option = document.createElement('option');
            option.value = opt.label;
            option.textContent = opt.label;
            sel.appendChild(option);
          });
          fieldDiv.appendChild(lbl);
          fieldDiv.appendChild(sel);

        } else if (field.type === 'CHECKBOX') {
          div = document.createElement('div');
          div.style.cssText = 'display:flex; align-items:center; gap:8px;';
          inp = document.createElement('input');
          inp.type = 'checkbox';
          inp.dataset.pfLabel = field.label;
          inp.dataset.pfValue = 'Yes';
          inp.style.cssText = 'width:16px; height:16px; cursor:pointer; flex-shrink:0; accent-color:' + styles.inputBorderColor + ';';
          lbl = document.createElement('label');
          lbl.textContent = field.label;
          lbl.style.cssText = 'font-size:' + styles.labelSize + '; color:' + styles.labelColor + '; cursor:pointer;';
          div.appendChild(inp);
          div.appendChild(lbl);
          fieldDiv.appendChild(div);

        } else if (field.type === 'AGREEMENT') {
          div = document.createElement('div');
          div.style.cssText = 'display:flex; align-items:flex-start; gap:8px; padding:12px; background:' + styles.agreementBg + '; border-radius:' + styles.inputBorderRadius + '; border:1px solid ' + styles.agreementBorderColor + ';';
          inp = document.createElement('input');
          inp.type = 'checkbox';
          inp.dataset.pfLabel = field.label;
          inp.dataset.pfValue = 'Agreed';
          inp.style.cssText = 'width:16px; height:16px; cursor:pointer; flex-shrink:0; margin-top:2px; accent-color:' + styles.inputBorderColor + ';';
          lbl = document.createElement('label');
          lbl.textContent = field.label;
          lbl.style.cssText = 'font-size:' + styles.labelSize + '; color:' + styles.labelColor + '; cursor:pointer; line-height:1.5;';
          div.appendChild(inp);
          div.appendChild(lbl);
          fieldDiv.appendChild(div);
        }

        wrapper.appendChild(fieldDiv);
      });

      container.appendChild(wrapper);

      // Intercept fetch requests to /cart/add
      var originalFetch = window.fetch;
      window.fetch = function(url, options) {
        if (typeof url === 'string' && url.includes('/cart/add')) {
          options = options || {};
          var wrapper = document.getElementById('pf-wrapper-' + blockId);
          
          // Collect field values
          var properties = {};
          if (wrapper) {
            wrapper.querySelectorAll('[data-pf-label]').forEach(function(el) {
              var label = el.dataset.pfLabel;
              if (el.type === 'checkbox') {
                if (el.checked) properties[label] = el.dataset.pfValue;
              } else if (el.value) {
                properties[label] = el.value;
              }
            });
          }

          // Handle JSON body
          if (options.body && typeof options.body === 'string') {
            try {
              var body = JSON.parse(options.body);
              body.properties = Object.assign(body.properties || {}, properties);
              options.body = JSON.stringify(body);
            } catch(e) {}
          }

          // Handle FormData body
          if (options.body instanceof FormData) {
            Object.keys(properties).forEach(function(key) {
              options.body.append('properties[' + key + ']', properties[key]);
            });
          }

          // If no body, create FormData
          if (!options.body) {
            var fd = new FormData();
            Object.keys(properties).forEach(function(key) {
              fd.append('properties[' + key + ']', properties[key]);
            });
            options.body = fd;
          }
        }
        return originalFetch.apply(this, arguments);
      };

      // Also intercept XMLHttpRequest
      var originalOpen = XMLHttpRequest.prototype.open;
      var originalSend = XMLHttpRequest.prototype.send;
      XMLHttpRequest.prototype.open = function(method, url) {
        this._url = url;
        return originalOpen.apply(this, arguments);
      };
      XMLHttpRequest.prototype.send = function(body) {
        if (this._url && this._url.includes('/cart/add') && body) {
          try {
            var data = JSON.parse(body);
            data.properties = data.properties || {};
            var wrapper = document.getElementById('pf-wrapper-' + blockId);
            if (wrapper) {
              wrapper.querySelectorAll('[data-pf-label]').forEach(function(el) {
                var label = el.dataset.pfLabel;
                if (el.type === 'checkbox') {
                  if (el.checked) data.properties[label] = el.dataset.pfValue;
                } else if (el.value) {
                  data.properties[label] = el.value;
                }
              });
            }
            body = JSON.stringify(data);
          } catch(e) {}
        }
        return originalSend.call(this, body);
      };
    })
    .catch(function(err) { console.error('Product fields error:', err); });
})();
</script>

{% schema %}
{
  "name": "Product Fields",
  "target": "section",
  "settings": [


    {
      "type": "header",
      "content": "Label styles"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Input styles"
    },
    {
      "type": "color",
      "id": "input_bg",
      "label": "Input background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "Input border color",
      "default": "#d1d5db"
    },
    {
      "type": "range",
      "id": "input_border_radius",
      "label": "Input border radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 6
    },
    {
      "type": "color",
      "id": "input_text_color",
      "label": "Input text color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Agreement box styles"
    },
    {
      "type": "color",
      "id": "agreement_bg",
      "label": "Agreement background color",
      "default": "#f9fafb"
    },
    {
      "type": "color",
      "id": "agreement_border_color",
      "label": "Agreement border color",
      "default": "#e5e7eb"
    }
  ]
}
{% endschema %}
