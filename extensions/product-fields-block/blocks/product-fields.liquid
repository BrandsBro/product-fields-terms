<div id="pf-block-{{ block.id }}"></div>

<script>
(function() {
  var shop = {{ shop.permanent_domain | json }};
  var productId = {{ product.id | json }};
  var blockId = "{{ block.id }}";
  var appUrl = {{ block.settings.app_url | json }};

  if (!appUrl) return;

  fetch(appUrl + '/api/fields?shop=' + shop + '&productId=' + productId)
    .then(function(res) { return res.json(); })
    .then(function(data) {
      var container = document.getElementById('pf-block-' + blockId);
      if (!container || !data.fields || data.fields.length === 0) return;

      var wrapper = document.createElement('div');
      wrapper.style.cssText = 'margin: 16px 0;';

      data.fields.forEach(function(field) {
        var fieldDiv = document.createElement('div');
        fieldDiv.style.cssText = 'margin-bottom: 12px;';

        if (field.type === 'TEXT') {
          var label = document.createElement('label');
          label.textContent = field.label + (field.required ? ' *' : '');
          label.style.cssText = 'display:block; margin-bottom:4px; font-weight:500;';
          
          var input = document.createElement('input');
          input.type = 'text';
          input.name = 'properties[' + field.label + ']';
          input.placeholder = field.placeholder || '';
          // required removed for v1
          input.style.cssText = 'width:100%; padding:8px; border:1px solid #ccc; border-radius:4px; box-sizing:border-box;';
          
          fieldDiv.appendChild(label);
          fieldDiv.appendChild(input);

        } else if (field.type === 'DROPDOWN') {
          var label = document.createElement('label');
          label.textContent = field.label + (field.required ? ' *' : '');
          label.style.cssText = 'display:block; margin-bottom:4px; font-weight:500;';
          
          var select = document.createElement('select');
          select.name = 'properties[' + field.label + ']';
          // required removed for v1
          select.style.cssText = 'width:100%; padding:8px; border:1px solid #ccc; border-radius:4px; box-sizing:border-box;';
          
          var defaultOpt = document.createElement('option');
          defaultOpt.value = '';
          defaultOpt.textContent = 'Select an option';
          select.appendChild(defaultOpt);
          
          (field.options || []).forEach(function(opt) {
            var option = document.createElement('option');
            option.value = opt.label;
            option.textContent = opt.label;
            select.appendChild(option);
          });
          
          fieldDiv.appendChild(label);
          fieldDiv.appendChild(select);

        } else if (field.type === 'CHECKBOX' || field.type === 'AGREEMENT') {
          var div = document.createElement('div');
          div.style.cssText = 'display:flex; align-items:center; gap:8px;';
          
          var input = document.createElement('input');
          input.type = 'checkbox';
          input.name = 'properties[' + field.label + ']';
          input.value = field.type === 'AGREEMENT' ? 'Agreed' : 'Yes';
          // required removed for v1
          
          var label = document.createElement('label');
          label.textContent = field.label + ' *';
          label.style.cssText = 'font-weight:500;';
          
          div.appendChild(input);
          div.appendChild(label);
          fieldDiv.appendChild(div);
        }

        wrapper.appendChild(fieldDiv);
      });

      container.appendChild(wrapper);
    })
    .catch(function(err) { console.error('Product fields error:', err); });
})();
</script>

{% schema %}
{
  "name": "Product Fields",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "app_url",
      "label": "App URL",
      "default": "https://product-fields-terms.onrender.com"
    }
  ]
}
{% endschema %}
